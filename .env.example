# Backend API base URL.
# Local dev default: http://localhost:8000
# Production: https://backend.olympus.athenio.ai
NEXT_PUBLIC_API_URL=http://localhost:8000

# Meta (Facebook/WhatsApp) OAuth app id — required only if the user flow
# reaches the WhatsApp channel connection wizard. Obtain from
# https://developers.facebook.com > your app > Settings > Basic.
NEXT_PUBLIC_META_APP_ID=

# --- Sentry ---
# DSN of this frontend's Sentry project (not the backend's). Safe to expose
# to the client bundle. When absent, the SDK stays a no-op so dev/preview
# builds never crash.
NEXT_PUBLIC_SENTRY_DSN=

# Secret auth token used during `next build` to upload source maps.
# Server-only — NEVER prefix with NEXT_PUBLIC_. Create at
# https://sentry.io/orgredirect/organizations/:org/settings/auth-tokens/
SENTRY_AUTH_TOKEN=

# Sentry organization slug.
SENTRY_ORG=

# Sentry project slug for this frontend.
SENTRY_PROJECT=
